<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Retromind.Models"
             xmlns:vm="clr-namespace:Retromind.ViewModels"
             xmlns:helpers="clr-namespace:Retromind.Helpers"
             xmlns:p="clr-namespace:Retromind.Resources"
             x:Class="Retromind.Views.MediaAreaView"
             x:DataType="vm:MediaAreaViewModel">

    <Grid RowDefinitions="Auto, *">
        <!-- Header bar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Margin="10">
                
            <!-- Title / Logo -->
            <Grid Grid.Column="0"
                  VerticalAlignment="Center"
                  Margin="0,0,20,0">
                <Image helpers:AsyncImageHelper.Url="{Binding Node.PrimaryLogoAbsolutePath}"
                       Height="32"
                       Stretch="Uniform"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       IsVisible="{Binding Node.PrimaryLogoAbsolutePath, Converter={x:Static helpers:StringConverters.IsNotNullOrEmpty}}"/>

                <TextBlock Text="{Binding Node.Name}"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           IsVisible="{Binding Node.PrimaryLogoAbsolutePath, Converter={x:Static helpers:StringConverters.IsNullOrEmpty}}"/>
            </Grid>

            <!-- Right side: Controls -->
            <WrapPanel Grid.Column="1"
                       Orientation="Horizontal"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center">
                    
                <!-- Random Button -->
                <Button Command="{Binding PlayRandomCommand}" 
                        ToolTip.Tip="{x:Static p:Strings.Tip_RandomGame}"
                        Padding="10,5"
                        Margin="0,0,12,8"
                        IsEnabled="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsLaunchIdle}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="🎲"/>
                        <TextBlock Text="{x:Static p:Strings.Button_Random}"/>
                    </StackPanel>
                </Button>

                <!-- Favorites-only toggle -->
                <CheckBox IsChecked="{Binding OnlyFavorites}"
                          Margin="0,0,12,8"
                          VerticalAlignment="Center"
                          ToolTip.Tip="{x:Static p:Strings.Common_FavoritesOnlyHint}">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="★"/>
                        <TextBlock Text="{x:Static p:Strings.Common_FavoritesOnly}"/>
                    </StackPanel>
                </CheckBox>
                
                <!-- Search -->
                <TextBox Text="{Binding SearchText}" 
                         PlaceholderText="{x:Static p:Strings.Search_Search}" 
                         Width="260"
                         Margin="0,0,6,8"
                         VerticalAlignment="Center"/>

                <Button Width="26"
                        Height="28"
                        Padding="0"
                        Margin="0,0,6,8"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Command="{Binding ClearSearchTextCommand}"
                        ToolTip.Tip="{x:Static p:Strings.Search_ClearSearchTextTooltip}">
                    <TextBlock Text="✕"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Button Width="26"
                        Height="28"
                        Padding="0"
                        Margin="0,0,6,8"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Click="OnOpenFilterBuilderClick"
                        ToolTip.Tip="{x:Static p:Strings.Search_AddFieldFilterTooltip}">
                    <Path Data="M 2 3 L 14 3 L 9 8 L 9 13 L 7 12 L 7 8 Z"
                          Width="12"
                          Height="12"
                          Stretch="Uniform"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Button>

                <Border Width="18"
                        Height="18"
                        Margin="0,0,12,8"
                        VerticalAlignment="Center"
                        CornerRadius="10"
                        Background="LightGray"
                        Cursor="Help">
                    <ToolTip.Tip>
                        <ToolTip MaxWidth="420">
                            <TextBlock Text="{x:Static p:Strings.Search_SyntaxHelpTooltip}"
                                       TextWrapping="Wrap" />
                        </ToolTip>
                    </ToolTip.Tip>
                    <TextBlock Text="?"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="Gray"/>
                </Border>
                
                <!-- Zoom Slider -->
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static p:Strings.Zoom_Zoom}" VerticalAlignment="Center" />
                    <Slider Value="{Binding ItemWidth}" Minimum="50" Maximum="300" Width="150" />
                </StackPanel>

            </WrapPanel>
        </Grid>

        <!-- The Media-List -->
        <!-- IMPORTANT: ItemsSource changed to FilteredItems -->
        <ListBox x:Name="MediaList"
                 Grid.Row="1"
                 ItemsSource="{Binding ItemRows}"
                 Padding="0"
                 Background="Transparent"
                 Focusable="True"
                 KeyDown="OnMediaListKeyDown">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Focusable" Value="False" />
                </Style>
                <Style Selector="ListBoxItem:pointerover">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                </Style>
                <Style Selector="ListBoxItem:selected">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                </Style>
                <Style Selector="ListBoxItem:focus">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                </Style>
            </ListBox.Styles>

            <!-- Context menu for the EMPTY area -->
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{x:Static p:Strings.Ctx_Media_Add}"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AddMediaCommand}"
                              CommandParameter="{Binding Node}" />
                    <MenuItem Header="{x:Static p:Strings.Import_Folder}"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ImportRomsCommand}"
                              CommandParameter="{Binding Node}" />
                </ContextMenu>
            </ListBox.ContextMenu>

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <!-- Appearance of a single row -->
            <ListBox.ItemTemplate>
                <DataTemplate x:CompileBindings="False">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <!-- Appearance of a single item -->
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <!-- The width is bound to the slider in the ViewModel -->
                                <Border Width="{Binding DataContext.EffectiveItemWidth, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        Height="{Binding DataContext.EffectiveItemWidth, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        Margin="0,10"
                                        Padding="0,10"
                                        CornerRadius="0"
                                        ClipToBounds="True"
                                        PointerPressed="OnItemPointerPressed"
                                        DoubleTapped="OnItemDoubleTapped">

                                    <Border.Background>
                                        <MultiBinding Converter="{x:Static helpers:ObjectConverters.TileBackground}">
                                            <Binding />
                                            <Binding Path="DataContext.SelectedMediaItem"
                                                     RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                            <Binding Path="IsPointerOver"
                                                     RelativeSource="{RelativeSource Self}" />
                                        </MultiBinding>
                                    </Border.Background>

                                    <Border.BorderThickness>0</Border.BorderThickness>

                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{x:Static p:Strings.Button_Edit}"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).EditMediaCommand}"
                                                      CommandParameter="{Binding .}" 
                                                      FontWeight="Bold"/>
                                            <MenuItem Header="{x:Static p:Strings.Dialog_LoadMetadata}"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ScrapeMediaCommand}"
                                                      CommandParameter="{Binding .}" />
                                            <MenuItem Header="{x:Static p:Strings.Ctx_Media_AddManual}"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AddManualToMediaCommand}"
                                                      CommandParameter="{Binding .}" />
                                            <Separator/>
                                            <MenuItem Header="{x:Static p:Strings.Button_Delete}"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteMediaCommand}"
                                                      CommandParameter="{Binding .}"
                                                      Foreground="Red" />
                                            <Separator/>
                                            <MenuItem Header="{x:Static p:Strings.Ctx_Media_Add}"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AddMediaCommand}"
                                                      CommandParameter="{Binding DataContext.Node, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                            <MenuItem Header="{x:Static p:Strings.Import_Folder}"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ImportRomsCommand}"
                                                      CommandParameter="{Binding DataContext.Node, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <Grid>
                                        <!-- Title: Only visible if there is NO CoverPath -->
                                        <TextBlock Text="{Binding Title}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   Margin="5"
                                                   Foreground="Gold"
                                                   IsVisible="{Binding PrimaryCoverPath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />

                                        <Image helpers:AsyncImageHelper.Url="{Binding PrimaryCoverPath}"
                                               helpers:AsyncImageHelper.DecodeWidth="300" 
                                               Stretch="Uniform"
                                               IsVisible="{Binding PrimaryCoverPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
