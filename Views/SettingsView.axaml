<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Retromind.ViewModels"
        xmlns:p="clr-namespace:Retromind.Resources"
        xmlns:models="clr-namespace:Retromind.Models"
        x:Class="Retromind.Views.SettingsView"
        x:DataType="vm:SettingsViewModel"
        Title="{x:Static p:Strings.Settings_Title}"
        Width="750" Height="550"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="*, Auto" Margin="20">
        
        <!-- Main Content with Tabs -->
        <TabControl Grid.Row="0"
                    SelectedIndex="{Binding SelectedSettingsTabIndex, Mode=TwoWay}">
            <TabControl.Styles>
                <Style Selector="TabControl > TabItem">
                    <Setter Property="FontSize" Value="18" />
                    <Setter Property="Padding" Value="10,6" />
                </Style>
            </TabControl.Styles>
            
            <!-- TAB 1: EMULATORS -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding SettingsTabEmulatorsShort}"
                               ToolTip.Tip="{x:Static p:Strings.Settings_TabEmulators}" />
                </TabItem.Header>
                <Grid ColumnDefinitions="200, 20, *">
                    <!-- LEFT: List of emulators -->
                    <Grid Grid.Column="0" RowDefinitions="*, Auto">
                        <ListBox Grid.Row="0"
                                 ItemsSource="{Binding Emulators}"
                                 SelectedItem="{Binding SelectedEmulator}">
                            <ListBox.ItemTemplate>
                                <DataTemplate  x:DataType="models:EmulatorConfig">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="5" Margin="0,10,0,0">
                            <Button Content="+" Command="{Binding AddEmulatorCommand}" ToolTip.Tip="{x:Static p:Strings.Button_Add}" />
                            <Button Content="-" Command="{Binding RemoveEmulatorCommand}" ToolTip.Tip="{x:Static p:Strings.Button_Remove}" />
                        </StackPanel>
                    </Grid>

                    <!-- RIGHT: Emulator Details -->
                    <ScrollViewer Grid.Column="2">
                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="15"
                                IsVisible="{Binding SelectedEmulator, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <StackPanel Spacing="15" DataContext="{Binding SelectedEmulator}">
                                <TextBlock Text="{x:Static p:Strings.Settings_SectionEmulators}" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />

                                <!-- Name -->
                                <StackPanel>
                                    <TextBlock Text="{x:Static p:Strings.Settings_ProfileName}" FontWeight="Bold" />
                                    <TextBox Text="{Binding Name}" />
                                </StackPanel>

                                <!-- Path -->
                                <StackPanel>
                                    <TextBlock Text="{x:Static p:Strings.Settings_ExecutablePath}" FontWeight="Bold" />
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBox Grid.Column="0" Text="{Binding Path}" />
                                        <Button Grid.Column="1" Content="..."
                                                ToolTip.Tip="{x:Static p:Strings.Button_Browse}"
                                                Command="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).BrowsePathCommand}" Margin="5,0,0,0" />
                                    </Grid>
                                </StackPanel>

                                <!-- Arguments -->
                                <StackPanel>
                                    <TextBlock Text="{x:Static p:Strings.Settings_DefaultArguments}" FontWeight="Bold" />
                                    <TextBox Text="{Binding Arguments}" />
                                </StackPanel>

                                <!-- Advanced: Wine/Proton/UMU prefix -->
                                <Expander Header="{x:Static p:Strings.Settings_Advanced}" IsExpanded="False">
                                    <StackPanel Spacing="8">
                                        <CheckBox Content="{x:Static p:Strings.Settings_UseWinePrefix}"
                                                  IsChecked="{Binding UsesWinePrefix}"
                                                  ToolTip.Tip="{x:Static p:Strings.Settings_UseWinePrefix_Hint}" />

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).EmulatorRunnerTypeLabel}"
                                                       FontWeight="Bold" />
                                            <ComboBox ItemsSource="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).AvailableEmulatorRunnerTypes}"
                                                      SelectedItem="{Binding RunnerType}"
                                                      HorizontalAlignment="Stretch" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).EmulatorRunnerVersionLabel}"
                                                       FontWeight="Bold" />
                                            <ComboBox ItemsSource="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).SelectedEmulatorRunnerVersionOptions}"
                                                      SelectedItem="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).SelectedEmulatorRunnerVersion}"
                                                      IsEnabled="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).IsEmulatorRunnerSelectionEnabled}"
                                                      HorizontalAlignment="Stretch">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Text="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).EmulatorRunnerDisabledHint}"
                                                       IsVisible="{Binding !$parent[Window].((vm:SettingsViewModel)DataContext).IsEmulatorRunnerSelectionEnabled}"
                                                       Opacity="0.6"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <CheckBox Content="{x:Static p:Strings.Settings_UsePlaylistForMultiDisc}"
                                                  IsChecked="{Binding UsePlaylistForMultiDisc}"
                                                  ToolTip.Tip="{x:Static p:Strings.Settings_UsePlaylistForMultiDisc_Hint}" />
                                    </StackPanel>
                                </Expander>

                                <!-- Emulator XDG context -->
                                <StackPanel Spacing="6" Margin="0,10,0,0">
                                    <TextBlock Text="{x:Static p:Strings.Settings_EmulatorXdgContextTitle}" FontWeight="Bold" />
                                    <TextBlock Text="{x:Static p:Strings.Settings_EmulatorXdgContextHint}"
                                               Opacity="0.65" TextWrapping="Wrap" />
                                    <ComboBox ItemsSource="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).AvailableEmulatorXdgModes}"
                                              SelectedItem="{Binding XdgMode}"
                                              HorizontalAlignment="Stretch" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button Content="{x:Static p:Strings.Settings_EmulatorXdgPresetPortable}"
                                                Command="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).ApplyPortableXdgPresetCommand}" />
                                        <Button Content="{x:Static p:Strings.Settings_EmulatorXdgPresetPortableHome}"
                                                Command="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).ApplyPortableXdgAndHomePresetCommand}" />
                                    </StackPanel>
                                    <TextBlock Text="{x:Static p:Strings.Settings_EmulatorXdgPresetTip}"
                                               Opacity="0.6" TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Spacing="8"
                                            IsVisible="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).IsEmulatorXdgCustomSelected}">
                                    <StackPanel>
                                        <TextBlock Text="XDG_CONFIG_HOME" FontWeight="Bold" />
                                        <TextBox Text="{Binding XdgConfigPath}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="XDG_DATA_HOME" FontWeight="Bold" />
                                        <TextBox Text="{Binding XdgDataPath}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="XDG_CACHE_HOME" FontWeight="Bold" />
                                        <TextBox Text="{Binding XdgCachePath}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="XDG_STATE_HOME" FontWeight="Bold" />
                                        <TextBox Text="{Binding XdgStatePath}" />
                                    </StackPanel>
                                </StackPanel>
                                
                                <!-- Native wrapper chain (Linux, emulator-level) -->
                                <StackPanel Spacing="8" Margin="0,10,0,0"
                                            DataContext="{Binding $parent[Window].((vm:SettingsViewModel)DataContext)}">
                                    <TextBlock Text="{x:Static p:Strings.Settings_NativeWrapperTitle}" FontWeight="Bold" />

                                    <CheckBox Content="{x:Static p:Strings.Settings_UseGlobalWrapperDefaults}"
                                              IsChecked="{Binding UseGlobalWrapperDefaults}" />

                                    <StackPanel IsEnabled="{Binding IsEmulatorWrapperListEnabled}">
                                        <Button Content="{x:Static p:Strings.Settings_AddWrapper}"
                                                Command="{Binding AddEmulatorWrapperCommand}"
                                                HorizontalAlignment="Left" />

                                        <ItemsControl ItemsSource="{Binding EmulatorNativeWrappers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#10000000" CornerRadius="4" Padding="8" Margin="0,5,0,0">
                                                        <Grid ColumnDefinitions="*, 10, *, 10, Auto" RowDefinitions="Auto, Auto" >
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static p:Strings.Settings_WrapperPathLabel}" />
                                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{x:Static p:Strings.Settings_WrapperArgsLabel}" />

                                                             <TextBox Grid.Row="1" Grid.Column="0"
                                                                     Text="{Binding Path, Mode=TwoWay}"
                                                                     Watermark="{x:Static p:Strings.Settings_WrapperPathWatermark}" />

                                                            <TextBox Grid.Row="1" Grid.Column="2"
                                                                     Text="{Binding Args, Mode=TwoWay}" />

                                                            <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal" Spacing="5">
                                                                <Button Content="↑"
                                                                        ToolTip.Tip="{x:Static p:Strings.Settings_MoveUp}"
                                                                        Command="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).MoveEmulatorWrapperUpCommand}"
                                                                        CommandParameter="{Binding}" />
                                                                <Button Content="↓"
                                                                        ToolTip.Tip="{x:Static p:Strings.Settings_MoveDown}"
                                                                        Command="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).MoveEmulatorWrapperDownCommand}"
                                                                        CommandParameter="{Binding}" />
                                                                <Button Content="✕"
                                                                        Command="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).RemoveEmulatorWrapperCommand}"
                                                                        CommandParameter="{Binding .}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                                
                                <!-- Emulator-level environment variables -->
                                <StackPanel Spacing="8" Margin="0,10,0,0"
                                            DataContext="{Binding $parent[Window].((vm:SettingsViewModel)DataContext)}">
                                    <TextBlock Text="{x:Static p:Strings.Settings_EmulatorEnvTitle}" FontWeight="Bold" />

                                    <Button Content="{x:Static p:Strings.Settings_AddVariable}"
                                            Command="{Binding AddEmulatorEnvVarCommand}"
                                            HorizontalAlignment="Left" />

                                    <ItemsControl ItemsSource="{Binding EmulatorEnvironmentOverrides}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="*, 10, * , Auto" Margin="0,5,0,0">
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{x:Static p:Strings.Settings_EnvKeyLabel}" />
                                                        <TextBox Text="{Binding Key, Mode=TwoWay}"
                                                                 Watermark="{x:Static p:Strings.Settings_EnvKeyWatermark}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="{x:Static p:Strings.Settings_EnvValueLabel}" />
                                                        <TextBox Text="{Binding Value, Mode=TwoWay}"
                                                                 Watermark="{x:Static p:Strings.Settings_EnvValueWatermark}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="3"
                                                            Content="✕"
                                                            Margin="5,18,0,0"
                                                            Command="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).RemoveEmulatorEnvVarCommand}"
                                                            CommandParameter="{Binding .}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            
            <!-- TAB 2: METADATA (SCRAPER) -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding SettingsTabMetadataShort}"
                               ToolTip.Tip="{x:Static p:Strings.Settings_TabMetadata}" />
                </TabItem.Header>
                <Grid ColumnDefinitions="200, 20, *">
                    <!-- LEFT: List of scrapers -->
                    <Grid Grid.Column="0" RowDefinitions="*, Auto">
                        <ListBox Grid.Row="0"
                                 ItemsSource="{Binding Scrapers}"
                                 SelectedItem="{Binding SelectedScraper}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="5" Margin="0,10,0,0">
                            <Button Content="+" Command="{Binding AddScraperCommand}" ToolTip.Tip="{x:Static p:Strings.Button_Add}" />
                            <Button Content="-" Command="{Binding RemoveScraperCommand}" ToolTip.Tip="{x:Static p:Strings.Button_Remove}" />
                        </StackPanel>
                    </Grid>
                    
                    <!-- RIGHT: Scraper Details -->
                    <ScrollViewer Grid.Column="2"> 
                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="15"
                                IsVisible="{Binding SelectedScraper, Converter={x:Static ObjectConverters.IsNotNull}}">
    
                            <StackPanel Spacing="15" DataContext="{Binding SelectedScraper}">
                                <TextBlock Text="{x:Static p:Strings.Dialog_ConfigureMetadata}" FontWeight="Bold" FontSize="16"
                                           Margin="0,0,0,10" />
    
                                <!-- Name -->
                                <StackPanel>
                                    <TextBlock Text="{x:Static p:Strings.Metadata_Designation}" FontWeight="Bold" />
                                    <TextBox Text="{Binding Name}" />
                                </StackPanel>
                                
                                <!-- Type -->
                                <StackPanel>
                                    <TextBlock Text="{x:Static p:Strings.Metadata_Type}" FontWeight="Bold" />
                                    <ComboBox ItemsSource="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).AvailableScraperTypes}"
                                              SelectedItem="{Binding Type}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                
                                <Separator Height="1" Background="Gray" Opacity="0.5" Margin="0,10"/>
                                
                                <TextBlock Text="{x:Static p:Strings.Metadata_AccessData}" FontWeight="Bold" FontSize="14" Margin="0,5,0,0"/>
    
                                <!-- IGDB Fields -->
                                <StackPanel IsVisible="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).IsIgdbSelected}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static p:Strings.Metadata_Client}" FontWeight="Bold" />
                                            <TextBlock Text="{x:Static p:Strings.Hint_Required}" FontSize="10" Foreground="Red" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                                        </StackPanel>
                                        <TextBox Text="{Binding ClientId}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,10,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static p:Strings.Metadata_ClientSecret}" FontWeight="Bold" />
                                            <TextBlock Text="{x:Static p:Strings.Hint_Required}" FontSize="10" Foreground="Red" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                                        </StackPanel>
                                        <TextBox Text="{Binding ClientSecret}" PasswordChar="*" />
                                    </StackPanel>
                                </StackPanel>
                                
                                <!-- Login Fields (EmuMovies) -->
                                <StackPanel IsVisible="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).IsEmuMoviesSelected}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static p:Strings.Common_UserName}" FontWeight="Bold" />
                                            <TextBlock Text="{x:Static p:Strings.Hint_Required}" FontSize="10" Foreground="Red" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                                        </StackPanel>
                                        <TextBox Text="{Binding Username}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,10,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static p:Strings.Common_Password}" FontWeight="Bold" />
                                            <TextBlock Text="{x:Static p:Strings.Hint_Required}" FontSize="10" Foreground="Red" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                                        </StackPanel>
                                        <TextBox Text="{Binding Password}" PasswordChar="*" />
                                    </StackPanel>
                                </StackPanel>
                                
                                <!-- API Key (TMDB & Others) -->
                                <StackPanel IsVisible="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).IsApiKeyUsedSelected}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{x:Static p:Strings.Metadata_ApiKey}" FontWeight="Bold" />
                                        <TextBlock Text="{x:Static p:Strings.Hint_Required}"
                                                   IsVisible="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).IsApiKeyRequiredSelected}"
                                                   FontSize="10" Foreground="Red" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                                        <TextBlock Text="{x:Static p:Strings.Hint_TmdbKey}"
                                                   IsVisible="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).IsGoogleBooksSelected}"
                                                   FontSize="10" Opacity="0.6" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding ApiKey}" PasswordChar="*" />
                                </StackPanel>

                                <!-- Language (Supported by selected scraper) -->
                                <StackPanel IsVisible="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).IsLanguageSelectionSupported}">
                                    <TextBlock Text="{x:Static p:Strings.Metadata_DataLanguage}" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <ComboBox SelectedItem="{Binding Language}" HorizontalAlignment="Stretch">
                                        <ComboBox.Items>
                                            <x:String>de-DE</x:String>
                                            <x:String>en-US</x:String>
                                        </ComboBox.Items>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                    
                     <!-- Fallback when no scraper selected -->
                    <TextBlock Grid.Column="2"
                               Text="{x:Static p:Strings.Dialog_ChooseASource}"
                               VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5"
                               IsVisible="{Binding SelectedScraper, Converter={x:Static ObjectConverters.IsNull}}" />
                </Grid>
            </TabItem>

            <!-- TAB 3: RUNNER VERSIONS -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding SettingsTabRunnerShort}"
                               ToolTip.Tip="{Binding RunnerVersionsTabTitle}" />
                </TabItem.Header>
                <Grid ColumnDefinitions="260, 20, *">
                    <Grid Grid.Column="0" RowDefinitions="Auto, *, Auto" RowSpacing="8">
                        <TextBlock Grid.Row="0"
                                   Text="{Binding RunnerVersionsSectionTitle}"
                                   FontWeight="Bold"
                                   FontSize="16" />

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding RunnerVersions}"
                                 SelectedItem="{Binding SelectedRunnerVersion}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                        <TextBlock Text="{Binding KindDisplay}" Opacity="0.8" FontSize="11" />
                                        <TextBlock Text="{Binding Path}" Opacity="0.7" FontSize="11" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Grid.Row="2"
                                Content="{x:Static p:Strings.Button_Remove}"
                                Command="{Binding RemoveRunnerVersionCommand}" />
                    </Grid>

                    <ScrollViewer Grid.Column="2">
                        <StackPanel Spacing="10" Margin="0,0,8,0">
                            <TextBlock Text="{Binding RunnerVersionDefaultPathHint}"
                                       Opacity="0.6"
                                       TextWrapping="Wrap" />

                            <StackPanel>
                                <TextBlock Text="{Binding RunnerVersionNameLabel}" FontWeight="Bold" />
                                <TextBox Text="{Binding RunnerVersionNameInput}" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="{Binding RunnerVersionPathLabel}" FontWeight="Bold" />
                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                    <TextBox Grid.Column="0" Text="{Binding RunnerVersionPathInput}" />
                                    <Button Grid.Column="1"
                                            Content="{x:Static p:Strings.Button_Browse}"
                                            Command="{Binding BrowseRunnerVersionPathCommand}" />
                                </Grid>
                            </StackPanel>

                            <Button Content="{x:Static p:Strings.Button_Add}"
                                    Command="{Binding AddRunnerVersionCommand}"
                                    HorizontalAlignment="Left" />

                            <Separator Height="1" Background="Gray" Opacity="0.5" Margin="0,5" />

                            <TextBlock Text="{Binding GeProtonSectionTitle}" FontWeight="Bold" FontSize="16" />
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding GeProtonSelectionLabel}" FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding GeProtonReleases}"
                                          SelectedItem="{Binding SelectedGeProtonRelease}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="{Binding GeProtonRefreshLabel}"
                                            Command="{Binding RefreshGeReleasesCommand}" />
                                    <Button Content="{Binding GeProtonDownloadLabel}"
                                            Command="{Binding DownloadSelectedGeReleaseCommand}" />
                                </StackPanel>
                                <TextBlock Text="{Binding GeProtonStatusLabel}" FontWeight="Bold" />
                                <TextBlock Text="{Binding GeReleaseStatusText}"
                                           Opacity="0.7"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Separator Height="1" Background="Gray" Opacity="0.5" Margin="0,5" />

                            <TextBlock Text="{Binding RunnerVersionUsageLabel}" FontWeight="Bold" />
                            <TextBlock Text="{Binding SelectedRunnerVersion.UsedByGames}" FontSize="20" FontWeight="Bold" />

                            <StackPanel IsVisible="{Binding IsRunnerReplacementVisible}" Spacing="6">
                                <TextBlock Text="{Binding RunnerReplacementLabel}" FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding RunnerReplacementOptions}"
                                          SelectedItem="{Binding SelectedRunnerReplacement}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="{Binding RunnerReplacementHint}"
                                           Opacity="0.6"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- TAB 4: MISC -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding SettingsTabMiscShort}"
                               ToolTip.Tip="{x:Static p:Strings.Settings_TabMisc}" />
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Spacing="15" Margin="0,0,10,0">
                        <TextBlock Text="{x:Static p:Strings.Settings_SectionLaunchPaths}" FontWeight="Bold" FontSize="16" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <CheckBox IsChecked="{Binding PreferPortableLaunchPaths}"
                                      Content="{x:Static p:Strings.Settings_PortableLaunchPaths}" />
                            <Button Content="{x:Static p:Strings.Settings_ConvertExistingLaunchPaths}"
                                    Command="{Binding ConvertExistingToPortableCommand}" />
                        </StackPanel>
                        <CheckBox Content="{x:Static p:Strings.Settings_PortableHome}"
                                  IsChecked="{Binding UsePortableHomeInAppImage, Mode=OneWay}"
                                  Click="OnPortableHomeClick"
                                  ToolTip.Tip="{x:Static p:Strings.Settings_PortableHome_Hint}" />

                        <Separator Height="1" Background="Gray" Opacity="0.5" Margin="0,5"/>

                        <TextBlock Text="{x:Static p:Strings.Settings_SectionMusic}" FontWeight="Bold" FontSize="16" />
                        <CheckBox Content="{x:Static p:Strings.Settings_PlayRandomMusic}"
                                  IsChecked="{Binding EnableSelectionMusicPreview}"
                                  ToolTip.Tip="{x:Static p:Strings.Settings_PlayRandomMusic_Hint}" />

                        <Separator Height="1" Background="Gray" Opacity="0.5" Margin="0,5"/>

                        <TextBlock Text="{Binding ScraperImportSectionTitle}" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="{Binding ScraperImportHint}"
                                   Opacity="0.6" TextWrapping="Wrap" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding ScraperExistingDataModeText}" FontWeight="Bold" />
                            <ComboBox ItemsSource="{Binding AvailableScraperExistingDataModes}"
                                      SelectedItem="{Binding ScraperExistingDataMode}"
                                      HorizontalAlignment="Stretch" />
                            <CheckBox Content="{Binding ScraperBulkAppendAssetsText}"
                                      IsChecked="{Binding ScraperAppendAssetsDuringBulkScrape}" />
                            <TextBlock Text="{Binding ScraperBulkAppendAssetsHint}"
                                       Opacity="0.6"
                                       Margin="20,0,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                            <Border Grid.Column="0"
                                    BorderBrush="Gray"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="{Binding ScraperMetadataFieldsText}" FontWeight="Bold" />
                                    <CheckBox Content="{x:Static p:Strings.Common_Description}" IsChecked="{Binding ScraperImportDescription}" />
                                    <CheckBox Content="{x:Static p:Strings.Common_ReleaseDate}" IsChecked="{Binding ScraperImportReleaseDate}" />
                                    <CheckBox Content="{x:Static p:Strings.Common_Rating}" IsChecked="{Binding ScraperImportRating}" />
                                    <CheckBox Content="{x:Static p:Strings.Common_Developer}" IsChecked="{Binding ScraperImportDeveloper}" />
                                    <CheckBox Content="{x:Static p:Strings.Common_Genre}" IsChecked="{Binding ScraperImportGenre}" />
                                    <CheckBox Content="{x:Static p:Strings.Common_Platform}" IsChecked="{Binding ScraperImportPlatform}" />
                                    <CheckBox Content="{x:Static p:Strings.Common_Publisher}" IsChecked="{Binding ScraperImportPublisher}" />
                                    <CheckBox Content="{x:Static p:Strings.Common_Series}" IsChecked="{Binding ScraperImportSeries}" />
                                    <CheckBox Content="{x:Static p:Strings.Common_ReleaseType}" IsChecked="{Binding ScraperImportReleaseType}" />
                                    <CheckBox Content="{x:Static p:Strings.Common_SortTitle}" IsChecked="{Binding ScraperImportSortTitle}" />
                                    <CheckBox Content="{x:Static p:Strings.Common_PlayMode}" IsChecked="{Binding ScraperImportPlayMode}" />
                                    <CheckBox Content="{x:Static p:Strings.Common_MaxPlayers}" IsChecked="{Binding ScraperImportMaxPlayers}" />
                                    <CheckBox Content="{x:Static p:Strings.Common_Source}" IsChecked="{Binding ScraperImportSource}" />
                                    <CheckBox Content="{x:Static p:Strings.Common_CustomFields}" IsChecked="{Binding ScraperImportCustomFields}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    BorderBrush="Gray"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="{Binding ScraperAssetFieldsText}" FontWeight="Bold" />
                                    <CheckBox Content="{x:Static p:Strings.Button_Cover}" IsChecked="{Binding ScraperImportCover}" />
                                    <CheckBox Content="{x:Static p:Strings.NodeSettings_ArtworkWallpaperLabel}" IsChecked="{Binding ScraperImportWallpaper}" />
                                    <CheckBox Content="{x:Static p:Strings.Button_Screenshot}" IsChecked="{Binding ScraperImportScreenshot}" />
                                    <CheckBox Content="{x:Static p:Strings.Button_Logo}" IsChecked="{Binding ScraperImportLogo}" />
                                    <CheckBox Content="{x:Static p:Strings.NodeSettings_ArtworkMarqueeLabel}" IsChecked="{Binding ScraperImportMarquee}" />
                                    <CheckBox Content="{x:Static p:Strings.Button_Bezel}" IsChecked="{Binding ScraperImportBezel}" />
                                    <CheckBox Content="{x:Static p:Strings.Button_ControlPanel}" IsChecked="{Binding ScraperImportControlPanel}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Separator Height="1" Background="Gray" Opacity="0.5" Margin="0,5"/>

                        <TextBlock Text="{Binding ParentalSectionTitle}" FontWeight="Bold" FontSize="16" />
                        <Button Content="{Binding ChangeParentalPasswordText}"
                                Command="{Binding ChangeParentalPasswordCommand}"
                                HorizontalAlignment="Left" />

                        <Separator Height="1" Background="Gray" Opacity="0.5" Margin="0,5"/>

                        <TextBlock Text="{x:Static p:Strings.Settings_SectionSteamLibrary}" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="{x:Static p:Strings.Settings_SteamLibraryPathsHint}"
                                   Opacity="0.6" TextWrapping="Wrap" />
                        <ListBox ItemsSource="{Binding SteamLibraryPaths}"
                                 SelectedItem="{Binding SelectedSteamLibraryPath}"
                                 MinHeight="80" />
                        <Grid ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="8">
                            <TextBox Grid.Column="0"
                                     Text="{Binding SteamLibraryPathInput}"
                                     Watermark="{x:Static p:Strings.Settings_SteamLibraryPathWatermark}" />
                            <Button Grid.Column="1"
                                    Content="{x:Static p:Strings.Button_Browse}"
                                    Command="{Binding BrowseSteamLibraryPathCommand}" />
                            <Button Grid.Column="2"
                                    Content="{x:Static p:Strings.Button_Add}"
                                    Command="{Binding AddSteamLibraryPathCommand}" />
                            <Button Grid.Column="3"
                                    Content="{x:Static p:Strings.Button_Remove}"
                                    Command="{Binding RemoveSteamLibraryPathCommand}" />
                        </Grid>

                        <Separator Height="1" Background="Gray" Opacity="0.5" Margin="0,5"/>

                        <TextBlock Text="{x:Static p:Strings.Settings_SectionHeroicGog}" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="{x:Static p:Strings.Settings_HeroicGogPathsHint}"
                                   Opacity="0.6" TextWrapping="Wrap" />
                        <ListBox ItemsSource="{Binding HeroicGogConfigPaths}"
                                 SelectedItem="{Binding SelectedHeroicGogPath}"
                                 MinHeight="80" />
                        <Grid ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="8">
                            <TextBox Grid.Column="0"
                                     Text="{Binding HeroicGogPathInput}"
                                     Watermark="{x:Static p:Strings.Settings_HeroicGogPathWatermark}" />
                            <Button Grid.Column="1"
                                    Content="{x:Static p:Strings.Button_Browse}"
                                    Command="{Binding BrowseHeroicGogPathCommand}" />
                            <Button Grid.Column="2"
                                    Content="{x:Static p:Strings.Button_Add}"
                                    Command="{Binding AddHeroicGogPathCommand}" />
                            <Button Grid.Column="3"
                                    Content="{x:Static p:Strings.Button_Remove}"
                                    Command="{Binding RemoveHeroicGogPathCommand}" />
                        </Grid>

                        <Separator Height="1" Background="Gray" Opacity="0.5" Margin="0,5"/>

                        <TextBlock Text="{x:Static p:Strings.Settings_SectionHeroicEpic}" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="{x:Static p:Strings.Settings_HeroicEpicPathsHint}"
                                   Opacity="0.6" TextWrapping="Wrap" />
                        <ListBox ItemsSource="{Binding HeroicEpicConfigPaths}"
                                 SelectedItem="{Binding SelectedHeroicEpicPath}"
                                 MinHeight="80" />
                        <Grid ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="8">
                            <TextBox Grid.Column="0"
                                     Text="{Binding HeroicEpicPathInput}"
                                     Watermark="{x:Static p:Strings.Settings_HeroicEpicPathWatermark}" />
                            <Button Grid.Column="1"
                                    Content="{x:Static p:Strings.Button_Browse}"
                                    Command="{Binding BrowseHeroicEpicPathCommand}" />
                            <Button Grid.Column="2"
                                    Content="{x:Static p:Strings.Button_Add}"
                                    Command="{Binding AddHeroicEpicPathCommand}" />
                            <Button Grid.Column="3"
                                    Content="{x:Static p:Strings.Button_Remove}"
                                    Command="{Binding RemoveHeroicEpicPathCommand}" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
        </TabControl>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Content="{x:Static p:Strings.Button_Save}" Command="{Binding SaveCommand}" Classes="accent"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
