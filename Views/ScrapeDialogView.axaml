<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Retromind.ViewModels"
        xmlns:p="clr-namespace:Retromind.Resources"
        xmlns:helpers="clr-namespace:Retromind.Helpers"
        x:Class="Retromind.Views.ScrapeDialogView"
        x:DataType="vm:ScrapeDialogViewModel"
        Title="{x:Static p:Strings.Metadata_SearchMetadata}"
        Width="1180" Height="700"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto, *, Auto" Margin="20">

        <!-- Header / Search -->
        <Grid Grid.Row="0" RowDefinitions="Auto, Auto" ColumnDefinitions="*, 10, Auto" Margin="0,0,0,20">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static p:Strings.Dialog_ChooseSource}" Margin="0,0,0,5"/>
            <ComboBox Grid.Row="1" Grid.Column="0"
                      ItemsSource="{Binding AvailableScrapers}"
                      SelectedItem="{Binding SelectedScraper}"
                      HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="{x:Static p:Strings.Dialog_SearchTerm}" Margin="0,0,0,5"/>
            <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Spacing="10">
                <TextBox Text="{Binding SearchQuery}" Width="500" />
                <Button Content="{x:Static p:Strings.Search_Search}" Command="{Binding SearchCommand}" IsDefault="True"/>
            </StackPanel>
        </Grid>

        <!-- Results -->
        <Grid Grid.Row="1" ColumnDefinitions="2.0*, 10, 2.0*, 10, 1.5*">

            <!-- List -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                <ListBox ItemsSource="{Binding SearchResults}"
                         SelectedItem="{Binding SelectedResult}"
                         Background="Transparent">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="60, *">
                                <!-- Async thumbnail (downsampled) -->
                                <Border Grid.Column="0" Width="50" Height="70" Background="#EEE" Margin="0,5,10,5">
                                    <Image helpers:AsyncImageHelper.Url="{Binding CoverUrl}"
                                           helpers:AsyncImageHelper.DecodeWidth="100"
                                           Stretch="Uniform"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding ReleaseDate, StringFormat={}{0:yyyy}}"
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding Platform}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="320"
                                               IsVisible="{Binding Platform}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Status message overlay (no Grid.Row to avoid undefined row issues) -->
            <TextBlock Grid.Column="0" Grid.ColumnSpan="5"
                       Text="{Binding StatusMessage}"
                       Foreground="Red"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Background="#CCFFFFFF"
                       Padding="10"/>

            <!-- Preview metadata (middle) -->
            <ScrollViewer Grid.Column="2">
                <StackPanel Spacing="10">
                    <TextBlock Text="{x:Static p:Strings.Common_PreviewShort}" FontWeight="Bold" FontSize="16"/>

                    <TextBlock Text="Source" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SelectedResult.Source}" TextWrapping="Wrap"/>

                    <TextBlock Text="ID" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SelectedResult.Id}" TextWrapping="Wrap"/>

                    <TextBlock Text="{x:Static p:Strings.Common_TitleEx}" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding SelectedResult.Title}" TextWrapping="Wrap"/>

                    <TextBlock Text="{x:Static p:Strings.Common_ReleaseDate}" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding SelectedResult.ReleaseDate, StringFormat={}{0:yyyy-MM-dd}}" />

                    <TextBlock Text="{x:Static p:Strings.Common_Developer}" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding SelectedResult.Developer}" TextWrapping="Wrap"/>

                    <TextBlock Text="{x:Static p:Strings.Common_Publisher}" FontWeight="Bold" Margin="0,10,0,0"
                               IsVisible="{Binding SelectedResult.Publisher, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="{Binding SelectedResult.Publisher}" TextWrapping="Wrap"
                               IsVisible="{Binding SelectedResult.Publisher, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <TextBlock Text="{x:Static p:Strings.Common_Genre}" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding SelectedResult.Genre}" TextWrapping="Wrap"/>

                    <TextBlock Text="{x:Static p:Strings.Common_Series}" FontWeight="Bold" Margin="0,10,0,0"
                               IsVisible="{Binding SelectedResult.Series, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="{Binding SelectedResult.Series}" TextWrapping="Wrap"
                               IsVisible="{Binding SelectedResult.Series, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <TextBlock Text="{x:Static p:Strings.Common_ReleaseType}" FontWeight="Bold" Margin="0,10,0,0"
                               IsVisible="{Binding SelectedResult.ReleaseType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="{Binding SelectedResult.ReleaseType}" TextWrapping="Wrap"
                               IsVisible="{Binding SelectedResult.ReleaseType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <TextBlock Text="{x:Static p:Strings.Common_SortTitle}" FontWeight="Bold" Margin="0,10,0,0"
                               IsVisible="{Binding SelectedResult.SortTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="{Binding SelectedResult.SortTitle}" TextWrapping="Wrap"
                               IsVisible="{Binding SelectedResult.SortTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <TextBlock Text="{x:Static p:Strings.Common_PlayMode}" FontWeight="Bold" Margin="0,10,0,0"
                               IsVisible="{Binding SelectedResult.PlayMode, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="{Binding SelectedResult.PlayMode}" TextWrapping="Wrap"
                               IsVisible="{Binding SelectedResult.PlayMode, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <TextBlock Text="{x:Static p:Strings.Common_MaxPlayers}" FontWeight="Bold" Margin="0,10,0,0"
                               IsVisible="{Binding SelectedResult.MaxPlayers, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="{Binding SelectedResult.MaxPlayers}" TextWrapping="Wrap"
                               IsVisible="{Binding SelectedResult.MaxPlayers, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <TextBlock Text="{x:Static p:Strings.Common_Description}" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding SelectedResult.Description}" TextWrapping="Wrap" FontSize="12"/>

                    <TextBlock Text="{x:Static p:Strings.Common_Rating}" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding SelectedResult.Rating}" />
                    
                    <TextBlock Text="Platform" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding SelectedResult.Platform}" TextWrapping="Wrap"/>

                    <TextBlock Text="{x:Static p:Strings.Common_CustomFields}" FontWeight="Bold" Margin="0,10,0,0"
                               IsVisible="{Binding SelectedResult.HasCustomFields}"/>
                    <ItemsControl ItemsSource="{Binding SelectedResult.VisibleCustomFields}"
                                  IsVisible="{Binding SelectedResult.HasCustomFields}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock TextWrapping="Wrap">
                                    <Run Text="{Binding Key}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding Value}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Preview images (right) -->
            <ScrollViewer Grid.Column="4">
                <StackPanel Spacing="10">
                    <TextBlock Text="Images" FontWeight="Bold" FontSize="16"/>

                    <StackPanel Spacing="5"
                                IsVisible="{Binding SelectedResult.CoverUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="Cover" FontWeight="Bold"/>
                        <Image helpers:AsyncImageHelper.Url="{Binding SelectedResult.CoverUrl}"
                               helpers:AsyncImageHelper.DecodeWidth="500"
                               Width="220" Height="320"
                               Stretch="Uniform"/>
                        <TextBlock Text="{Binding SelectedResult.CoverUrl}" TextWrapping="Wrap" FontSize="10"/>
                    </StackPanel>

                    <StackPanel Spacing="5"
                                IsVisible="{Binding SelectedResult.WallpaperUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="Wallpaper" FontWeight="Bold"/>
                        <Image helpers:AsyncImageHelper.Url="{Binding SelectedResult.WallpaperUrl}"
                               helpers:AsyncImageHelper.DecodeWidth="700"
                               Width="220" Height="124"
                               Stretch="UniformToFill"/>
                        <TextBlock Text="{Binding SelectedResult.WallpaperUrl}" TextWrapping="Wrap" FontSize="10"/>
                    </StackPanel>

                    <StackPanel Spacing="5"
                                IsVisible="{Binding SelectedResult.ScreenshotUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="Screenshot" FontWeight="Bold"/>
                        <Image helpers:AsyncImageHelper.Url="{Binding SelectedResult.ScreenshotUrl}"
                               helpers:AsyncImageHelper.DecodeWidth="700"
                               Width="220" Height="124"
                               Stretch="UniformToFill"/>
                        <TextBlock Text="{Binding SelectedResult.ScreenshotUrl}" TextWrapping="Wrap" FontSize="10"/>
                    </StackPanel>

                    <StackPanel Spacing="5"
                                IsVisible="{Binding SelectedResult.LogoUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="Logo" FontWeight="Bold"/>
                        <Image helpers:AsyncImageHelper.Url="{Binding SelectedResult.LogoUrl}"
                               helpers:AsyncImageHelper.DecodeWidth="500"
                               Width="220" Height="80"
                               Stretch="Uniform"/>
                        <TextBlock Text="{Binding SelectedResult.LogoUrl}" TextWrapping="Wrap" FontSize="10"/>
                    </StackPanel>

                    <StackPanel Spacing="5"
                                IsVisible="{Binding SelectedResult.MarqueeUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="Marquee" FontWeight="Bold"/>
                        <Image helpers:AsyncImageHelper.Url="{Binding SelectedResult.MarqueeUrl}"
                               helpers:AsyncImageHelper.DecodeWidth="700"
                               Width="220" Height="80"
                               Stretch="Uniform"/>
                        <TextBlock Text="{Binding SelectedResult.MarqueeUrl}" TextWrapping="Wrap" FontSize="10"/>
                    </StackPanel>

                    <StackPanel Spacing="5"
                                IsVisible="{Binding SelectedResult.BezelUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="Bezel" FontWeight="Bold"/>
                        <Image helpers:AsyncImageHelper.Url="{Binding SelectedResult.BezelUrl}"
                               helpers:AsyncImageHelper.DecodeWidth="700"
                               Width="220" Height="124"
                               Stretch="Uniform"/>
                        <TextBlock Text="{Binding SelectedResult.BezelUrl}" TextWrapping="Wrap" FontSize="10"/>
                    </StackPanel>

                    <StackPanel Spacing="5"
                                IsVisible="{Binding SelectedResult.ControlPanelUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="Control Panel" FontWeight="Bold"/>
                        <Image helpers:AsyncImageHelper.Url="{Binding SelectedResult.ControlPanelUrl}"
                               helpers:AsyncImageHelper.DecodeWidth="700"
                               Width="220" Height="124"
                               Stretch="Uniform"/>
                        <TextBlock Text="{Binding SelectedResult.ControlPanelUrl}" TextWrapping="Wrap" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Loading overlay -->
            <Border Grid.Column="0" Grid.ColumnSpan="5" Background="#80000000" IsVisible="{Binding IsBusy}">
                <TextBlock Text="{x:Static p:Strings.Metadata_Search_InProgress}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Foreground="White"
                           FontSize="20"/>
            </Border>
        </Grid>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Content="{x:Static p:Strings.Button_Cancel}" Click="CloseWindow"/>
            <Button Content="{x:Static p:Strings.Button_TakeOver}" Command="{Binding ApplyCommand}" Classes="accent"/>
        </StackPanel>
    </Grid>
</Window>
