<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Retromind.ViewModels"
        xmlns:p="clr-namespace:Retromind.Resources"
        x:Class="Retromind.Views.SearchQueryBuilderDialogView"
        x:DataType="vm:SearchQueryBuilderViewModel"
        Title="{x:Static p:Strings.Search_FilterBuilderTitle}"
        Width="620"
        Height="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Window.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding AddTokenCommand}" />
        <KeyBinding Gesture="Ctrl+Enter" Command="{Binding ReplaceSearchCommand}" />
    </Window.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" Margin="20">
        <TextBlock Grid.Row="0"
                   Text="{x:Static p:Strings.Search_FilterBuilderIntro}"
                   Margin="0,0,0,14"
                   TextWrapping="Wrap"
                   Opacity="0.8"/>

        <Grid Grid.Row="1" ColumnDefinitions="90,*" Margin="0,0,0,10">
            <TextBlock Grid.Column="0"
                       Text="{x:Static p:Strings.Search_FilterBuilderField}"
                       VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding FieldOptions}"
                      SelectedItem="{Binding SelectedField, Mode=TwoWay}"
                      MinWidth="{Binding FieldComboMinWidth}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="90,*" Margin="0,0,0,10">
            <TextBlock Grid.Column="0"
                       Text="{Binding MatchModeLabel}"
                       VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding MatchModeOptions}"
                      SelectedItem="{Binding SelectedMatchMode, Mode=TwoWay}"
                      MinWidth="170"
                      HorizontalAlignment="Left">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <Grid Grid.Row="3" ColumnDefinitions="90,*" Margin="0,0,0,10">
            <TextBlock Grid.Column="0"
                       Text="{x:Static p:Strings.Search_FilterBuilderValue}"
                       VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding ValueSuggestions}"
                      Text="{Binding ValueText, Mode=TwoWay}"
                      IsEnabled="{Binding IsValueInputEnabled}"
                      IsEditable="True"
                      MaxDropDownHeight="220"
                      HorizontalAlignment="Stretch" />
        </Grid>

        <Grid Grid.Row="4" ColumnDefinitions="90,*,Auto,Auto" Margin="0,0,0,10">
            <TextBlock Grid.Column="0"
                       Text="{Binding JoinLabel}"
                       VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding JoinOperatorOptions}"
                      SelectedItem="{Binding SelectedJoinOperator, Mode=TwoWay}"
                      MinWidth="110"
                      HorizontalAlignment="Left">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <CheckBox Grid.Column="2"
                      IsChecked="{Binding NegateToken, Mode=TwoWay}"
                      Content="{Binding NegateLabel}"
                      VerticalAlignment="Center"
                      Margin="14,0,0,0"/>

            <CheckBox Grid.Column="3"
                      IsChecked="{Binding WrapTokenInParentheses, Mode=TwoWay}"
                      Content="{Binding GroupLabel}"
                      VerticalAlignment="Center"
                      Margin="14,0,0,0"/>
        </Grid>

        <TextBlock Grid.Row="5"
                   Text="{x:Static p:Strings.Search_FilterBuilderApplyHint}"
                   Margin="0,0,0,16"
                   TextWrapping="Wrap"
                   Opacity="0.75"/>

        <Grid Grid.Row="6" ColumnDefinitions="Auto,*,Auto,Auto">
            <Button Content="{Binding ClearLabel}"
                    Command="{Binding ClearSearchCommand}"
                    Grid.Column="0" />
            <Button Content="{x:Static p:Strings.Search_FilterBuilderAdd}"
                    Command="{Binding AddTokenCommand}"
                    Grid.Column="2"
                    Margin="10,0,0,0" />
            <Button Content="{x:Static p:Strings.Search_FilterBuilderReplace}"
                    Command="{Binding ReplaceSearchCommand}"
                    Grid.Column="3"
                    Margin="10,0,0,0" />
        </Grid>
    </Grid>
</Window>
