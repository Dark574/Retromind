<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Retromind.ViewModels"
        x:Class="Retromind.Views.PasswordPromptView"
        x:DataType="vm:PasswordPromptViewModel"
        Title="{Binding Title}"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        ShowInTaskbar="False">

    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" MaxWidth="360" />

        <StackPanel>
            <TextBlock Text="{Binding PasswordLabel}" Margin="0,0,0,4" />
            <TextBox x:Name="PasswordBox"
                     Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                     PasswordChar="*"
                     Width="320" />
        </StackPanel>

        <StackPanel IsVisible="{Binding RequireConfirmation}">
            <TextBlock Text="{Binding ConfirmPasswordLabel}" Margin="0,0,0,4" />
            <TextBox Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}"
                     PasswordChar="*"
                     Width="320" />
        </StackPanel>

        <TextBlock Text="{Binding ValidationMessage}"
                   Foreground="Tomato"
                   IsVisible="{Binding HasValidationMessage}" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button Content="{Binding OkButtonText}"
                    IsDefault="True"
                    Command="{Binding OkCommand}"
                    CommandParameter="{Binding $parent[Window]}" />
            <Button Content="{Binding CancelButtonText}"
                    IsCancel="True"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding $parent[Window]}" />
        </StackPanel>
    </StackPanel>
</Window>
