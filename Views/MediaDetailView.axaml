<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:Retromind.Models"
             xmlns:helpers="clr-namespace:Retromind.Helpers"
             xmlns:vm="clr-namespace:Retromind.ViewModels"
             xmlns:p="clr-namespace:Retromind.Resources"
             xmlns:ext="clr-namespace:Retromind.Extensions;assembly=Retromind"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="600"
             x:Class="Retromind.Views.MediaDetailView"
             x:DataType="models:MediaItem">

    <UserControl.Resources>
        <helpers:TimeSpanToHumanReadableConverter x:Key="TimeConverter" />
        <helpers:BoolToOpacityConverter x:Key="VisibleWhenTrue" TrueOpacity="1" FalseOpacity="0" />
        <helpers:BoolToOpacityConverter x:Key="VisibleWhenFalse" TrueOpacity="0" FalseOpacity="1" />
        
        <!-- Pencil icon geometry (vector) -->
        <Geometry x:Key="IconPencilGeometry">
            M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm2.92 2.83H5v-.92l8.06-8.06.92.92L5.92 20.08zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34a.9959.9959 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z
        </Geometry>
        <!-- Key icon geometry (vector, so color can be styled) -->
        <Geometry x:Key="IconKeyGeometry">
            M7 14.4A4.9 4.9 0 1 1 11.61 8H22V9.4H20.6V11.1H19.2V12.8H17.8V11.1H16.4V9.8H11.61A4.9 4.9 0 0 1 7 14.4ZM7 12A2.5 2.5 0 1 0 7 7A2.5 2.5 0 0 0 7 12Z
        </Geometry>
        <!-- Maps file extensions like .pdf / .txt to simple glyph icons -->
        <helpers:FileExtensionToGlyphConverter x:Key="FileExtensionToGlyphConverter" />
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Margin="15" Spacing="15">

            <Grid>
                <!-- 1) Header area (logo or title fallback) -->
                <Grid MinHeight="80" Margin="0,0,40,0">
                    <StackPanel Spacing="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top">
                        <!-- Title shown when the item has no logo -->
                        <TextBlock Text="{Binding Title}"
                                   FontSize="28" FontWeight="Bold" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   IsVisible="{Binding PrimaryLogoPath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />

                        <!-- Logo (item logo or fallback) -->
                        <ext:CrossfadeImage x:CompileBindings="False"
                               Url="{Binding $parent[Window].DataContext.ResolvedSelectedItemLogoPath}"
                               DecodeWidth="400"
                               DisableCache="True"
                               Stretch="Uniform"
                               FadeDurationMs="1600"
                               MaxHeight="150"
                               HorizontalAlignment="Center"
                               IsVisible="{Binding $parent[Window].DataContext.ResolvedSelectedItemLogoPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                </Grid>

                <!-- Edit button (top-right) -->
                <Button ToolTip.Tip="{x:Static p:Strings.Button_Edit}"
                        Width="30" Height="30"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).EditMediaCommand}"
                        CommandParameter="{Binding .}">
                    <PathIcon Data="{StaticResource IconPencilGeometry}"
                            Width="18" Height="18" />
                </Button>
                
                <!-- Favorite toggle (top-left) -->
                <!-- Simple star toggle bound to MediaItem.IsFavorite -->
                <ToggleButton x:Name="FavoriteToggle"
                              Width="30" Height="30"
                              Padding="0"
                              Background="Transparent"
                              BorderThickness="0"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top"
                              ToolTip.Tip="Mark or unmark this item as a favorite."
                              IsChecked="{Binding IsFavorite}">
                    <!-- Custom template: no border, no background, just the content -->
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <ContentPresenter
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </ControlTemplate>
                    </ToggleButton.Template>

                    <ToggleButton.Styles>
                        <!-- Default: gray star -->
                        <Style Selector="ToggleButton#FavoriteToggle TextBlock#FavoriteStar">
                            <Setter Property="Foreground" Value="Gray" />
                        </Style>

                        <!-- When checked: gold star -->
                        <Style Selector="ToggleButton#FavoriteToggle:checked TextBlock#FavoriteStar">
                            <Setter Property="Foreground" Value="Gold" />
                        </Style>
                    </ToggleButton.Styles>

                    <TextBlock x:Name="FavoriteStar"
                               Text="★"
                               FontSize="22"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </ToggleButton>

                <Button x:Name="ProtectionButton"
                        Width="30" Height="30"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="36,0,0,0"
                        IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowParentalProtectionButton}"
                        ToolTip.Tip="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ParentalProtectButtonToolTip}"
                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleItemProtectionCommand}"
                        CommandParameter="{Binding .}">
                    <Grid>
                        <PathIcon Data="{StaticResource IconKeyGeometry}"
                                  Width="18" Height="18"
                                  Foreground="Gray"
                                  Opacity="{Binding IsProtected, Converter={StaticResource VisibleWhenFalse}}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center" />
                        <PathIcon Data="{StaticResource IconKeyGeometry}"
                                  Width="18" Height="18"
                                  Foreground="Gold"
                                  Opacity="{Binding IsProtected, Converter={StaticResource VisibleWhenTrue}}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center" />
                    </Grid>
                </Button>
            </Grid>

            <!-- Play button -->
            <Button Content="{x:Static p:Strings.Button_Play}"
                    Classes="accent"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Padding="0,2,0,0"
                    Height="40"
                    FontSize="18"
                    FontWeight="Bold"
                    Margin="0,10"
                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).PlayCommand}"
                    CommandParameter="{Binding .}"
                    IsEnabled="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsLaunchIdle}"/>

            <Separator Height="2" Background="Gray" Opacity="0.3" />

            <!-- Manuals / Documents area -->
            <!-- Shows one icon per attached manual asset (PDF, TXT, etc.) -->
            <ItemsControl ItemsSource="{Binding ManualAssets}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:MediaAsset">
                        <Button Width="32" Height="32"
                                Margin="0,0,6,0"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                ToolTip.Tip="{Binding DisplayLabel}"
                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenManualCommand}"
                                CommandParameter="{Binding .}">
                            <!-- Icon is chosen based on the file extension (pdf, txt, html, ...) -->
                            <TextBlock Text="{Binding RelativePath, Converter={StaticResource FileExtensionToGlyphConverter}}"
                                       FontSize="20"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 2) Metadata grid -->
            <Grid ColumnDefinitions="Auto, *"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                  Margin="0,5">
                <Grid.Styles>
                    <Style Selector="TextBlock.Label">
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="Gray" />
                        <Setter Property="Margin" Value="0,0,10,8" />
                        <Setter Property="VerticalAlignment" Value="Top" />
                    </Style>
                    <Style Selector="TextBlock.Value">
                        <Setter Property="TextWrapping" Value="Wrap" />
                        <Setter Property="Margin" Value="0,0,0,8" />
                    </Style>
                </Grid.Styles>

                <!-- Release date -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{x:Static p:Strings.Common_ReleaseDate}"
                           Classes="Label"
                           IsVisible="{Binding ReleaseDate, Converter={x:Static helpers:ObjectConverters.IsNotNull}}" />
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding ReleaseDate, StringFormat='{}{0:yyyy-MM-dd}'}"
                           Classes="Value"
                           IsVisible="{Binding ReleaseDate, Converter={x:Static helpers:ObjectConverters.IsNotNull}}" />

                <!-- Developer -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{x:Static p:Strings.Common_Developer}"
                           Classes="Label"
                           IsVisible="{Binding Developer, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding Developer}"
                           Classes="Value"
                           IsVisible="{Binding Developer, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- Publisher -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{x:Static p:Strings.Common_Publisher}"
                           Classes="Label"
                           IsVisible="{Binding Publisher, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Text="{Binding Publisher}"
                           Classes="Value"
                           IsVisible="{Binding Publisher, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- Genre -->
                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="{x:Static p:Strings.Common_Genre}"
                           Classes="Label"
                           IsVisible="{Binding Genre, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Grid.Row="3" Grid.Column="1"
                           Text="{Binding Genre}"
                           Classes="Value"
                           IsVisible="{Binding Genre, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- Platform -->
                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="{x:Static p:Strings.Common_Platform}"
                           Classes="Label"
                           IsVisible="{Binding Platform, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Grid.Row="4" Grid.Column="1"
                           Text="{Binding Platform}"
                           Classes="Value"
                           IsVisible="{Binding Platform, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- Series -->
                <TextBlock Grid.Row="5" Grid.Column="0"
                           Text="{x:Static p:Strings.Common_Series}"
                           Classes="Label"
                           IsVisible="{Binding Series, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Grid.Row="5" Grid.Column="1"
                           Text="{Binding Series}"
                           Classes="Value"
                           IsVisible="{Binding Series, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- Source -->
                <TextBlock Grid.Row="6" Grid.Column="0"
                           Text="{x:Static p:Strings.Common_Source}"
                           Classes="Label"
                           IsVisible="{Binding Source, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Grid.Row="6" Grid.Column="1"
                           Text="{Binding Source}"
                           Classes="Value"
                           IsVisible="{Binding Source, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- Release type -->
                <TextBlock Grid.Row="7" Grid.Column="0"
                           Text="{x:Static p:Strings.Common_ReleaseType}"
                           Classes="Label"
                           IsVisible="{Binding ReleaseType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Grid.Row="7" Grid.Column="1"
                           Text="{Binding ReleaseType}"
                           Classes="Value"
                           IsVisible="{Binding ReleaseType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- Sort title -->
                <TextBlock Grid.Row="8" Grid.Column="0"
                           Text="{x:Static p:Strings.Common_SortTitle}"
                           Classes="Label"
                           IsVisible="{Binding SortTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Grid.Row="8" Grid.Column="1"
                           Text="{Binding SortTitle}"
                           Classes="Value"
                           IsVisible="{Binding SortTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- Play mode -->
                <TextBlock Grid.Row="9" Grid.Column="0"
                           Text="{x:Static p:Strings.Common_PlayMode}"
                           Classes="Label"
                           IsVisible="{Binding PlayMode, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Grid.Row="9" Grid.Column="1"
                           Text="{Binding PlayMode}"
                           Classes="Value"
                           IsVisible="{Binding PlayMode, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- Max players -->
                <TextBlock Grid.Row="10" Grid.Column="0"
                           Text="{x:Static p:Strings.Common_MaxPlayers}"
                           Classes="Label"
                           IsVisible="{Binding MaxPlayers, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Grid.Row="10" Grid.Column="1"
                           Text="{Binding MaxPlayers}"
                           Classes="Value"
                           IsVisible="{Binding MaxPlayers, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- Last played -->
                <TextBlock Grid.Row="11" Grid.Column="0"
                           Text="{x:Static p:Strings.Media_LastPlayed}"
                           Classes="Label"
                           IsVisible="{Binding LastPlayed, Converter={x:Static helpers:ObjectConverters.IsNotNull}}" />
                <TextBlock Grid.Row="11" Grid.Column="1"
                           Text="{Binding LastPlayed, StringFormat='{}{0:g}'}"
                           Classes="Value"
                           IsVisible="{Binding LastPlayed, Converter={x:Static helpers:ObjectConverters.IsNotNull}}" />

                <!-- Total play time -->
                <TextBlock Grid.Row="12" Grid.Column="0" Text="{x:Static p:Strings.Media_PlayTime}" Classes="Label" />
                <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding TotalPlayTime, Converter={StaticResource TimeConverter}}" Classes="Value" />
            </Grid>

            <Separator Height="2" Background="Gray" Opacity="0.3" />

            <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding Status, Converter={x:Static helpers:ObjectConverters.IsNotNull}}">
                <TextBlock Grid.Column="0"
                           Text="{x:Static p:Strings.Common_Status}"
                           FontWeight="SemiBold"
                           Foreground="Gray"
                           Margin="0,0,10,8" />
                <TextBlock Grid.Column="1" Text="{Binding Status}" Margin="0,0,0,8" />
            </Grid>

            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0"
                           Text="{x:Static p:Strings.Media_PlayCount}"
                           FontWeight="SemiBold"
                           Foreground="Gray"
                           Margin="0,0,10,8" />
                <TextBlock Grid.Column="1" Text="{Binding PlayCount}" Margin="0,0,0,8" />
            </Grid>

            <StackPanel Spacing="5" IsVisible="{Binding HasCustomFields}">
                <TextBlock Text="{x:Static p:Strings.Common_CustomFields}" FontWeight="SemiBold" FontSize="16" />
                <ItemsControl x:CompileBindings="False"
                              ItemsSource="{Binding VisibleCustomFields}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,5">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Key}"
                                           FontWeight="SemiBold"
                                           Foreground="Gray"
                                           Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Value}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Separator Height="2" Background="Gray" Opacity="0.3" />

            <!-- 3) Summary -->
            <StackPanel Spacing="5"
                        IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{x:Static p:Strings.Common_Summary}" FontWeight="SemiBold" FontSize="16" />
                <TextBlock Text="{Binding Description}"
                           TextWrapping="Wrap"
                           LineHeight="22"
                           Opacity="0.8" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
