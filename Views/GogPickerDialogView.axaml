<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Retromind.ViewModels"
        x:Class="Retromind.Views.GogPickerDialogView"
        x:DataType="vm:GogPickerDialogViewModel"
        Title="{Binding DialogTitleText}"
        Width="980"
        Height="720"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="20">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" Margin="0,0,0,14">
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="{Binding HeaderText}"
                       FontSize="17"
                       FontWeight="Bold"/>

            <CheckBox Grid.Row="0"
                      Grid.Column="1"
                      Margin="14,0,0,0"
                      VerticalAlignment="Center"
                      IsChecked="{Binding OnlyNewInNode}"
                      Content="{Binding OnlyNewInNodeText}"/>

            <TextBox Grid.Row="1"
                     Grid.Column="0"
                     Grid.ColumnSpan="2"
                     Margin="0,8,0,0"
                     Height="30"
                     VerticalContentAlignment="Center"
                     Text="{Binding SearchText}"
                     PlaceholderText="{Binding SearchPlaceholderText}"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,10">
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding CounterText}"/>

            <Button Grid.Column="1"
                    Content="{Binding SelectAllFilteredText}"
                    Command="{Binding SelectAllFilteredCommand}"
                    Padding="10,4"/>

            <Button Grid.Column="2"
                    Margin="10,0,0,0"
                    Content="{Binding ClearFilteredSelectionText}"
                    Command="{Binding ClearFilteredSelectionCommand}"
                    Padding="10,4"/>
        </Grid>

        <Grid Grid.Row="2">
            <Border BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="4">
                <ListBox ItemsSource="{Binding FilteredGames}"
                         Background="Transparent">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:GogPickerGameEntry">
                            <Grid ColumnDefinitions="Auto,*,140,220"
                                  Margin="4,2">
                                <CheckBox Grid.Column="0"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center"
                                          IsEnabled="{Binding IsSelectionEnabled}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"/>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="1">
                                    <TextBlock Text="{Binding DisplayTitle}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding StoreGameId}"
                                               FontSize="11"
                                               Opacity="0.75"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="{Binding Platform}"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Column="3"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="{Binding StatusText}"
                                           TextTrimming="CharacterEllipsis"
                                           Opacity="0.8"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border IsVisible="{Binding ShowEmptyState}"
                    Background="#CCFFFFFF"
                    CornerRadius="4"
                    Padding="10,6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <TextBlock Text="{Binding EmptyStateText}"/>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="0,16,0,0">
            <Button Content="{Binding CancelText}"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"/>
            <Button Content="{Binding AddSelectionText}"
                    Command="{Binding ApplyCommand}"
                    Classes="accent"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
